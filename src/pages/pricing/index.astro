---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Rewards">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Rewards</p>
      <h1>Choose your path in the arena.</h1>
      <p class="lead">
        Start with a free Cheemy pack, then unlock booster bundles, season passes, and exclusive drops
        as you rise through the ranks.
      </p>
      <div class="grid pricing">
        <article class="card"><h3>Starter Pack</h3><p>Free Cheemy pack, basic deck, and access to casual matches.</p><strong>Free</strong></article>
        <article class="card"><h3>Booster Bundle</h3><p>10 Cheemy packs with a guaranteed Rare card and ranked match access.</p><strong>$14.99</strong></article>
        <article class="card"><h3>Season Pass</h3><p>Monthly exclusive drops, Legendary chances, tournament entry, and early expansion access.</p><strong>$29.99/mo</strong></article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing {
    margin-top: 42px;
  }

  strong {
    display: block;
    margin-top: 28px;
    font-size: 30px;
  }
</style>
