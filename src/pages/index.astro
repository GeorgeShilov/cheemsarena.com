---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const featured = posts.find((post) => post.featured) || posts[0];
---

<Layout title="Cheems Arena / Meme gaming arena" description={site.description}>
  <ArchiveNotice />
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Cheems Arena / Meme gaming arena</p>
      <h1>Where memes meet the arena.</h1>
      <p class="lead">
        Cheems Arena is the home for meme coin communities to compete, earn, and
        celebrate crypto culture. Tournaments, leaderboards, and on-chain rewards
        for the most based players.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Enter Arena Hub</a>
        <a class="button secondary" href="/blog/">Read arena notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Cheems Arena signal summary">
      <div>
        <span>Core view</span>
        <strong>Meme gaming arena</strong>
      </div>
      <div>
        <span>Signals</span>
        <strong>Tournaments, community, rewards</strong>
      </div>
      <div>
        <span>Launch stack</span>
        <strong>Cloudflare, Railway, Squidex</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>Meme coin communities need more than a chart to rally around.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Arena architecture</p>
      <h2>One arena for the culture-driven first mile of growth.</h2>
      <div class="grid">
        <article class="card">
          <h3>Tournament engine</h3>
          <p>Run brackets, prediction markets, and community events with on-chain verified results.</p>
        </article>
        <article class="card">
          <h3>Reward drops</h3>
          <p>Turn tournament outcomes into token distributions, NFT badges, and leaderboard prizes.</p>
        </article>
        <article class="card">
          <h3>Meme culture loop</h3>
          <p>Connect meme contests, community voting, and arena gameplay into one hype cycle.</p>
        </article>
      </div>
    </div>
  </section>

  {featured && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Featured note</p>
        <h2>Start with the arena.</h2>
        <PostCard post={featured} />
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background:
      linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #111827 100%);
    color: #fff;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(17, 24, 39, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow);
  }

  .hero-panel div {
    border-bottom: 1px solid #d9dee8;
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #5c6676;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #101828;
    font-size: 20px;
    line-height: 1.2;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #06b6d4;
    padding-left: 16px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      background-size: 720px;
      background-position: center bottom;
      padding-bottom: 300px;
    }
  }
</style>
