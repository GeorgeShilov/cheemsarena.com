---
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const sorted = [...posts].sort(
  (a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
);
const latest3 = sorted.slice(0, 3);
---

<Layout title="Cheems Arena / Trading card game ruled by Shiba" description={site.description}>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Cheems Arena / Trading card game ruled by Shiba</p>
      <h1>Have fun. Collect. Earn.</h1>
      <p class="lead">
        The first trading card game ruled by Shiba. Carved out of stone and marble
        by the shiba ancients, Cheems Arena is the violent hub that connects all
        elements of the Cheemsrealm. Build your deck, battle for glory, and own
        every card as a Solana NFT.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Enter Arena Hub</a>
        <a class="button secondary" href="/blog/">Read arena notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Cheems Arena signal summary">
      <div>
        <span>Core view</span>
        <strong>Blockchain TCG on Solana</strong>
      </div>
      <div>
        <span>Signals</span>
        <strong>350+ cards, NFT ownership, P2E</strong>
      </div>
      <div>
        <span>Network</span>
        <strong>Solana</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>Legends are born in the Cheemsrealm. Will you howl in victory or whimper in defeat?</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Arena architecture</p>
      <h2>One arena for the culture-driven first mile of growth.</h2>
      <div class="grid">
        <article class="card">
          <h3>The Cheemy packs</h3>
          <p>Four distinct card packs in the marketplace, each yielding 5 cards. Common, Rare, Epic, and Legendary — with specified drops by rarity.</p>
        </article>
        <article class="card">
          <h3>Real NFT ownership</h3>
          <p>Every card you purchase or earn is a real Solana NFT. Sell, trade, or hold — your collection is truly yours.</p>
        </article>
        <article class="card">
          <h3>Fast, low-cost battles</h3>
          <p>Cheems Arena leverages Solana's scalable blockchain for lightning-fast matches and near-zero transaction fees.</p>
        </article>
      </div>
    </div>
  </section>

  {latest3.length > 0 && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Latest arena notes</p>
        <h2>Fresh drops from the Cheemsrealm.</h2>
        <div class="latest-row">
          {latest3.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background:
      radial-gradient(600px 600px at 80% 20%, rgba(245, 158, 11, 0.15), transparent),
      radial-gradient(500px 500px at 10% 90%, rgba(236, 72, 153, 0.12), transparent),
      linear-gradient(135deg, #0c0a1a 0%, #14122a 40%, #0c0a1a 100%);
    color: #fafaf9;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 8px;
    background: rgba(20, 18, 42, 0.7);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 50px rgba(12, 10, 26, 0.4);
  }

  .hero-panel div {
    border-bottom: 1px solid rgba(245, 158, 11, 0.2);
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #f59e0b;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #fafaf9;
    font-size: 20px;
    line-height: 1.2;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #f59e0b;
    padding-left: 16px;
  }

  .hero .button {
    background: linear-gradient(135deg, #f59e0b, #ec4899);
    border-color: transparent;
    color: #0c0a1a;
  }

  .hero .button.secondary {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  .latest-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: 36px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      background-size: 720px;
      background-position: center bottom;
      padding-bottom: 300px;
    }

    .latest-row {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
