---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Privacy">
  <section class="section">
    <div class="section-inner article-body">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy policy</h1>
      <p>
        This site does not collect personal data beyond standard server logs. If you
        email the Cheems Arena contact address, your message and address are used only to respond.
      </p>
      <p>
        Hosting providers may collect standard server logs such as IP address, user agent, request
        path, and timestamp for security and operations.
      </p>
    </div>
  </section>
</Layout>
