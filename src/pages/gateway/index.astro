---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Arena Hub">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Arena Hub</p>
      <h1>Your hub for Cheems Arena battles and strategy.</h1>
      <p class="lead">
        Cheems Arena connects deck building, card trading, battles, and rewards into one seamless
        experience on Solana.
      </p>
      <div class="grid gateway-grid">
        <article class="card"><h3>1. Collect</h3><p>Open Cheemy packs and build your deck across four rarities and five elements.</p></article>
        <article class="card"><h3>2. Trade</h3><p>Buy, sell, and swap cards on the marketplace. Every card is a Solana NFT.</p></article>
        <article class="card"><h3>3. Battle</h3><p>Enter the arena, challenge opponents, and climb the leaderboard.</p></article>
        <article class="card"><h3>4. Earn</h3><p>Win rewards, complete quests, and turn your skill into collectibles.</p></article>
        <article class="card"><h3>5. Upgrade</h3><p>Fuse cards, unlock abilities, and refine your strategy.</p></article>
        <article class="card"><h3>6. Explore</h3><p>Discover lore, events, and new expansions across the Cheemsrealm.</p></article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gateway-grid {
    margin-top: 42px;
  }
</style>
