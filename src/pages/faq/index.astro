---
import Layout from "@/layouts/Layout.astro";

const faqs = [
  ["What is Cheems Arena?", "A trading card game ruled by Shiba on the Solana blockchain. Collect cards, build decks, battle opponents, and earn rewards."],
  ["How do I get cards?", "Purchase Cheemy packs from the marketplace. Each pack contains five cards with rarities from Common to Legendary."],
  ["Are the cards really NFTs?", "Yes. Every card is a minted Solana NFT. You truly own your collection and can trade or sell it freely."],
  ["What wallet do I need?", "Any Solana-compatible wallet works. Connect it to the marketplace to buy packs and manage your cards."]
];
---

<Layout title="FAQ">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">FAQ</p>
      <h1>Frequently asked questions.</h1>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details class="card">
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-list {
    display: grid;
    gap: 14px;
    margin-top: 40px;
  }

  summary {
    cursor: pointer;
    font-weight: 800;
    font-size: 20px;
  }

  details p {
    margin-top: 14px;
  }
</style>
