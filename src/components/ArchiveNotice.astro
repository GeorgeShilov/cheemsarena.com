---
import { site } from "@/config/site";
---

<section class="archive-notice">
  <div>
    <strong>Beta season</strong>
    <p>
      Cheems Arena is entering its first open beta: deck building, marketplace trading, and ranked
      battles are live on Solana. New cards, events, and rewards roll out every season.
    </p>
  </div>
  <a href={`mailto:${site.email}`}>Join the beta</a>
</section>

<style>
  .archive-notice {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 16px clamp(18px, 5vw, 64px);
    border-bottom: 1px solid rgba(245, 158, 11, 0.2);
    background: rgba(20, 18, 42, 0.8);
    backdrop-filter: blur(12px);
  }

  strong {
    display: block;
    margin-bottom: 2px;
    color: #f59e0b;
  }

  p {
    max-width: 860px;
    font-size: 14px;
    color: #a8a29e;
  }

  a {
    flex: 0 0 auto;
    color: #f59e0b;
    font-weight: 800;
  }

  a:hover {
    color: #ec4899;
  }

  @media (max-width: 700px) {
    .archive-notice {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
